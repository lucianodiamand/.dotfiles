#!/usr/bin/env bash
set -euo pipefail

BROWSER_TEXT="${BROWSER_TEXT:-w3m}"

strip_ansi() {
  sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g'
}

build_list() {
  buku -p |
    strip_ansi |
    awk '
      BEGIN {
        id=""; title=""; url=""; desc=""; tags=""
      }

      /^[0-9]+\./ {
        if (id != "") {
          printf "%s\t%s\t%s\t%s\t%s\n", id, title, url, desc, tags
        }

        id=$1
        sub(/\.$/, "", id)

        title=$0
        sub(/^[0-9]+\.[[:space:]]*/, "", title)

        url=""; desc=""; tags=""
        next
      }

      /^[[:space:]]+>[[:space:]]*/ {
        url=$0
        sub(/^[[:space:]]+>[[:space:]]*/, "", url)
        next
      }

      /^[[:space:]]+\+[[:space:]]*/ {
        desc=$0
        sub(/^[[:space:]]+\+[[:space:]]*/, "", desc)
        next
      }

      /^[[:space:]]+#[[:space:]]*/ {
        tags=$0
        sub(/^[[:space:]]+#[[:space:]]*/, "", tags)
        next
      }

      END {
        if (id != "") {
          printf "%s\t%s\t%s\t%s\t%s\n", id, title, url, desc, tags
        }
      }
    '
}

choice="$(
  build_list |
    awk -F '\t' '
      function trunc(s, n) {
        return (length(s) > n ? substr(s, 1, n - 1) "…" : s)
      }
      {
        title = trunc($2, 42)
        tags  = trunc($5, 24)
        display = sprintf("%-42s | %-24s | %s", title, tags, $3)
        printf "%s\t%s\t%s\t%s\t%s\t%s\n", display, $1, $2, $3, $4, $5
      }
    ' |
    fzf \
      --delimiter=$'\t' \
      --with-nth=1 \
      --preview '
        printf "Título: %s\n\n" {3}
        printf "URL: %s\n\n" {4}
        printf "Descripción: %s\n\n" {5}
        printf "Tags: %s\n" {6}
      ' \
      --preview-window=down:10:wrap \
      --height=80% \
      --layout=reverse \
      --prompt="Bookmarks> "
)"

[ -n "${choice:-}" ] || exit 0

url="$(printf '%s\n' "$choice" | awk -F '\t' '{print $4}')"
exec "$BROWSER_TEXT" "$url"
