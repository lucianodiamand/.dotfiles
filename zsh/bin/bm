#!/usr/bin/env bash
set -euo pipefail

BROWSER_TEXT="${BROWSER_TEXT:-w3m}"
BROWSER_GUI="${BROWSER_GUI:-firefox}"

strip_ansi() {
  sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g'
}

copy_to_clipboard() {
  local text="$1"

  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$text" | wl-copy
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$text" | xclip -selection clipboard
  elif command -v xsel >/dev/null 2>&1; then
    printf '%s' "$text" | xsel --clipboard --input
  else
    printf 'No encontré wl-copy, xclip ni xsel\n' >&2
    return 1
  fi
}

build_raw_list() {
  buku -p |
    strip_ansi |
    awk '
      BEGIN {
        id=""; title=""; url=""; desc=""; tags=""
      }

      /^[0-9]+\./ {
        if (id != "") {
          printf "%s\t%s\t%s\t%s\t%s\n", id, title, url, desc, tags
        }

        id=$1
        sub(/\.$/, "", id)

        title=$0
        sub(/^[0-9]+\.[[:space:]]*/, "", title)

        url=""; desc=""; tags=""
        next
      }

      /^[[:space:]]+>[[:space:]]*/ {
        url=$0
        sub(/^[[:space:]]+>[[:space:]]*/, "", url)
        next
      }

      /^[[:space:]]+\+[[:space:]]*/ {
        desc=$0
        sub(/^[[:space:]]+\+[[:space:]]*/, "", desc)
        next
      }

      /^[[:space:]]+#[[:space:]]*/ {
        tags=$0
        sub(/^[[:space:]]+#[[:space:]]*/, "", tags)
        next
      }

      END {
        if (id != "") {
          printf "%s\t%s\t%s\t%s\t%s\n", id, title, url, desc, tags
        }
      }
    '
}

build_display_list() {
  build_raw_list |
    awk -F '\t' '
      function trunc(s, n) {
        return (length(s) > n ? substr(s, 1, n - 1) "…" : s)
      }
      {
        title = trunc($2, 42)
        tags  = trunc($5, 24)
        display = sprintf("%-42s | %-24s | %s", title, tags, $3)
        printf "%s\t%s\t%s\t%s\t%s\t%s\n", display, $1, $2, $3, $4, $5
      }
    '
}

delete_bookmark() {
  local id="$1"
  buku -d "$id" >/dev/null
}

open_url_text() {
  local url="$1"
  exec "$BROWSER_TEXT" "$url"
}

open_url_gui() {
  local url="$1"
  exec "$BROWSER_GUI" "$url"
}

usage() {
  cat <<'EOF'
Uso:
  bm                   # abre selector interactivo
  bm --list            # imprime lista para fzf
  bm --delete ID       # borra bookmark por ID
  bm --copy URL        # copia URL al portapapeles
  bm --open-text URL   # abre URL con navegador texto
  bm --open-gui URL    # abre URL con navegador gráfico

Variables de entorno:
  BROWSER_TEXT=w3m
  BROWSER_GUI=firefox
EOF
}

case "${1:-}" in
  --list)
    build_display_list
    exit 0
    ;;
  --delete)
    [ $# -eq 2 ] || { usage >&2; exit 1; }
    delete_bookmark "$2"
    exit 0
    ;;
  --copy)
    [ $# -eq 2 ] || { usage >&2; exit 1; }
    copy_to_clipboard "$2"
    exit 0
    ;;
  --open-text)
    [ $# -eq 2 ] || { usage >&2; exit 1; }
    open_url_text "$2"
    ;;
  --open-gui)
    [ $# -eq 2 ] || { usage >&2; exit 1; }
    open_url_gui "$2"
    ;;
  --help|-h)
    usage
    exit 0
    ;;
esac

SELF="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"

"$SELF" --list |
  fzf \
    --delimiter=$'\t' \
    --with-nth=1 \
    --height=80% \
    --layout=reverse \
    --prompt="Bookmarks> " \
    --preview '
      printf "Título: %s\n\n" {3}
      printf "URL: %s\n\n" {4}
      printf "Descripción: %s\n\n" {5}
      printf "Tags: %s\n" {6}
    ' \
    --preview-window=down:10:wrap \
    --header $'Enter: Firefox  |  Ctrl-W: w3m  |  Ctrl-D: borrar  |  Ctrl-Y: copiar URL' \
    --bind "enter:become($SELF --open-gui {4})" \
    --bind "ctrl-w:become($SELF --open-text {4})" \
    --bind "ctrl-d:execute-silent($SELF --delete {2})+reload($SELF --list)" \
    --bind "ctrl-y:execute-silent($SELF --copy {4})"
